# AWS credentials for Remotion Lambda rendering
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Remotion Lambda config
REMOTION_REGION=us-east-1
REMOTION_FUNCTION_NAME=remotion-render-4-0-419-mem2048mb-disk2048mb-240sec
REMOTION_SERVE_URL=https://remotionlambda-useast1-ym4q2rm05p.s3.us-east-1.amazonaws.com/sites/my-video/index.html
REMOTION_BUCKET_NAME=remotionlambda-useast1-ym4q2rm05p

# --- API config ---

# Port the Express server listens on (default: 8000)
API_PORT=8000

# API key for authenticating requests (sent via x-api-key header)
API_KEY=

# Maximum number of concurrent render requests sent to Lambda
MAX_CONCURRENT_RENDERS=3

# Client webhook URL
WEBHOOK_URL=